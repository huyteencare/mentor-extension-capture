{
  "manifest_version": 3,
  "name": "Meet Capture - Mentor",
  "version": "2.0.0",
  "description": "Capture audio and video per student in Google Meet calls",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "http://160.191.244.71:8787/*",
    "https://ktbzdpbvthnejqjoueln.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Capture"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "viewer.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
